model PlanConception {
  id          String   @id @default(cuid())
  titre       String
  description String?
  type        String   @default("PLAN") // PLAN | RENDU_3D | COUPE | FACADE | IMPLANTATION | CALEPINAGE
  source      String?  // ARCHICAD | SKETCHUP | CEDREO | AUTOCAD | AUTRE
