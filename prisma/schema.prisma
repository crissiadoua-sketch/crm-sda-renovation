// ---------------------------------------------------------------------------
// Calcul structurel — Pré-dimensionnement (PDIM-YYYY-XXXX)
// Estimation rapide de sections (poutre/dalle/poteau) par ratios forfaitaires.
// Ce n'est PAS un calcul réglementaire détaillé : statut toujours "BROUILLON"
// jusqu'à contre-signature d'un ingénieur structure indépendant (hors outil).
// ---------------------------------------------------------------------------

model PreDimensionnement {
  id            String    @id @default(cuid())
  numero        String    @unique
  titre         String?
  statut        String    @default("BROUILLON") // BROUILLON uniquement en v1 (pas de workflow de validation)

  typeElement   String    // POUTRE | DALLE | POTEAU | DALLAGE
  materiau      String    // BETON | ACIER | BOIS

  // Poutre / dalle
  portee        Float?    // m
  condition     String?   // ISOSTATIQUE | CONTINUE | CONSOLE | PORTEE_1_SENS | PORTEE_2_SENS
  niveauCharge  String?   // LEGERE | NORMALE | LOURDE
  usagePreset   String?   // libellé du préset de pré-remplissage utilisé, le cas échéant

  // Dallage sur terre-plein (industriel / agricole / terrasse)
  usageDallage  String?   // INDUSTRIEL | AGRICOLE | TERRASSE | MARGELLE_PISCINE
  portanceSol   String?   // type de sol support (cf. PortanceSol)
  surface       Float?    // m², pour le métré (béton, treillis soudé)
  finitionBeton String?   // STANDARD | DESACTIVE | IMPRIME | CIRE | BALAYE (terrasse / margelle béton coulé)

  // Margelle de piscine (usageDallage = MARGELLE_PISCINE)
  materiauMargelle String? // BETON_COULE | PIERRE_RECONSTITUEE | PIERRE_NATURELLE | GRES_CERAME
  largeurMargelle  Float?  // cm
  debordMargelle   Float?  // cm, débord/égouttoir au-dessus du bassin
  lineaireM        Float?  // m, périmètre du bassin — pour le métré

  // Poteau
  effortNormal  Float?    // kN
  hauteurLibre  Float?    // m

  resistance    Float?    // MPa (fck béton / fy acier / fc0 bois) utilisée pour le calcul

  // Résultat
  resultatValeurCm  Float?
  resultatLargeurCm Float?
  resultatLabel     String?
  formule           String?
  hypotheses        String?   // texte multi-lignes, hypothèses tracées

  chantierId    String?
  responsable   String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chantier  Chantier? @relation("PDIMChantier", fields: [chantierId], references: [id], onDelete: SetNull)
  documents PreDimensionnementDocument[]
}

model PreDimensionnementDocument {
  id                   String    @id @default(cuid())
  preDimensionnementId String
  type                 String    // GEOTECHNIQUE_G2PRO | PLAN_NIVEAU | PLAN_COUPE | AUTRE
  nom                  String
  url                  String
  taille               Int
  analyseIA            String?   // cotes extraites automatiquement par l'IA (lecture à vérifier)
  analyseIADate        DateTime?
  createdAt            DateTime  @default(now())

  preDimensionnement PreDimensionnement @relation(fields: [preDimensionnementId], references: [id], onDelete: Cascade)
}
