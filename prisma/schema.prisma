// ---------------------------------------------------------------------------
// Bibliothèque matériaux & équipements (module Conception)
// ---------------------------------------------------------------------------

model ElementCatalogue {
  id            String   @id @default(cuid())
  // Catégories : MENUISERIE_INT | MOBILIER | MATERIAUX | MENUISERIE_EXT |
