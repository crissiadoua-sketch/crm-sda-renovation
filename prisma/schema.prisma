// ---------------------------------------------------------------------------
// Fiches techniques produits / matériaux / consommables
// ---------------------------------------------------------------------------

model FicheTechnique {
  id          String   @id @default(cuid())
  // Catégorie : PRODUIT | MATERIAU | CONSOMMABLE | EQUIPEMENT
  categorie   String   @default("PRODUIT")
  // Corps d'état : TER, MAC, DAL, COV, RAV, PLA, MEN, RSD, RSS, PEI, SER, etc.
  corpsEtat   String
  designation String
  marque      String?
  reference   String?
  description String?
  normes      String?  // normes applicables (CE, NF, ISO…)
  fichierPdf  String?  // chemin vers PDF de la fiche technique uploadé
  lienUrl     String?  // lien fabricant optionnel
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doeSections DOESection[] @relation("DOESectionFiches")
}

// ---------------------------------------------------------------------------
// DOE — Dossier des Ouvrages Exécutés
// ---------------------------------------------------------------------------

model DOE {
  id         String    @id @default(cuid())
  // Modèle : MARCHE_PUBLIC | PERSONNALISE
  modele     String    @default("PERSONNALISE")
  // Statut : BROUILLON | FINAL | TRANSMIS
  statut     String    @default("BROUILLON")
  titre      String
  reference  String?   // référence du marché (pour MARCHE_PUBLIC)
  intro      String?   // texte d'introduction
  conclusion String?   // texte de conclusion
  chantierId String
  devisId    String?   // devis source (auto-remplissage)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  chantier Chantier      @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  devis    Devis?        @relation(fields: [devisId], references: [id], onDelete: SetNull)
  sections DOESection[]
}

model DOESection {
  id            String   @id @default(cuid())
  doeId         String
  ordre         Int      @default(0)
  // Type : TRAVAUX | MATERIAUX | ATTESTATION | PLAN | NOTICE | GARANTIE | AUTRE
  type          String   @default("TRAVAUX")
  titre         String
  corpsEtat     String?  // corps d'état concerné
  description   String?  // texte descriptif des travaux réalisés
  fichiers      String?  // JSON string[] — chemins vers fichiers joints (photos, plans…)
