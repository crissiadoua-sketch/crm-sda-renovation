// ---------------------------------------------------------------------------
// Mutuelle — complémentaire santé d'entreprise (obligatoire ANI)
// ---------------------------------------------------------------------------

model ContratMutuelle {
  id            String    @id @default(cuid())
  // Organisme : Pro BTP | Malakoff Humanis | Apicil | AG2R La Mondiale | Autre
  organisme     String
  numeroContrat String?
  dateEffet     DateTime?
  dateFin       DateTime?
  actif         Boolean   @default(true)
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  formules  FormuleMutuelle[]
  adhesions AdhesionMutuelle[]
}

model FormuleMutuelle {
  id                  String  @id @default(cuid())
  contratMutuelleId   String
  // Niveau : BASE | OPTION_1 | OPTION_2 | OPTION_3
  niveau              String  @default("BASE")
  label               String  // "Formule Essentielle", "Formule Confort", "Formule Premium"
  cotisationSalarie   Float   @default(0) // mensuelle €
  cotisationPatronale Float   @default(0) // mensuelle €
  garanties           String? // description libre des garanties

