}

model MessagePieceJointe {
  id        String @id @default(cuid())
  messageId String
  nom       String
  url       String
  type      String
  taille    Int?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Mémoire Technique — 4 types × 2 modèles
// ---------------------------------------------------------------------------

model MemoireTechnique {
  id              String    @id @default(cuid())
  reference       String    @unique  // MT-2024-0001
  titre           String
  // TYPE_1 (5-10p <100k) | TYPE_2 (12p classique) | TYPE_3 (22p multi-lots) | TYPE_4 (30p gros marchés)
  type            String    @default("TYPE_2")
  // APPEL_OFFRE | CLIENT_SDA
  modele          String    @default("APPEL_OFFRE")
  statut          String    @default("BROUILLON") // BROUILLON | FINALISE | ENVOYE

  // Liens obligatoires
  chantierId      String
  devisId         String?

  // Méta-données marché
  maitreOuvrage   String?
  objetMarche     String?
  lotNumero       String?
  lotDesignation  String?
  montantEstime   Float?
  dateRemise      DateTime?

  // Contenu — JSON: { [sectionKey]: { titre, contenu, visible, ordre, nbPages } }
  sections        String    @default("{}")

  // Pages perso — JSON: { ajouts: PageAjout[], suppressions: string[] }
  pagesConfig     String    @default("{}")

  // Annexes — JSON: { id, nom, url, type, taille, dateAjout }[]
  annexes         String    @default("[]")

  // Layout — JSON: couleurs, police, espacements
  layoutConfig    String    @default("{}")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  chantier  Chantier  @relation(fields: [chantierId], references: [id])
  devis     Devis?    @relation(fields: [devisId], references: [id], onDelete: SetNull)
}

// ---------------------------------------------------------------------------
// Conception 3D — Projets BIM
// ---------------------------------------------------------------------------

model Projet3D {
  id          String   @id @default(cuid())
  titre       String
  description String?
  chantierId  String?
  // JSON: SceneElement[] — éléments placés dans la scène
  scene       String   @default("[]")
  // JSON: { longueur, largeur, unitePiece, niveaux }
  settings    String   @default("{}")
  // chemin vers screenshot aperçu
  apercu      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chantier Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
}

