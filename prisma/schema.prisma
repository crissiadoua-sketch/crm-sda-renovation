// ---------------------------------------------------------------------------

model DTU {
  id          String   @id @default(cuid())
  reference   String
  titre       String
  domaine     String   // TERRASSEMENT | MACONNERIE | BETON | DALLAGE | CHAPE | COUVERTURE | RAVALEMENT | PLATRERIE | MENUISERIE | AGENCEMENT | REVETEMENT_SOL | REVETEMENT_MURAL | PEINTURE | PLOMBERIE | ELECTRICITE | RENFORCEMENT_STRUCTUREL | AUTRE
