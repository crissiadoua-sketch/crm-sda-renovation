  image         String?  // chemin vers image de référence (JPG/PNG exporté depuis ArchiCAD, SketchUp, CEDREO…)
  fichierPlan   String?  // chemin vers plan PDF/image exporté depuis logiciel CAO
  notes         String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
