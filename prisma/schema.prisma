generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                    @id @default(cuid())
  name              String
  email             String                    @unique
  password          String
  role              String                    @default("DIRIGEANT")
  permissions       String                    @default("[]")
  passwordChangedAt DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  telephone         String?
  titre             String?
  adresse           String?
  societe           String?
  conversations     ConversationParticipant[]
  messagesSendus    Message[]
  rapports          RapportMensuel[]
  tachesAssignees   Tache[]                   @relation("TachesAssignees")
  tachesCrees       Tache[]                   @relation("TachesCrees")
}

model Client {
  id                    String                     @id @default(cuid())
  reference             String?                    @unique
  type                  String                     @default("PARTICULIER")
  civilite              String?
  nom                   String
  prenom                String?
  raisonSociale         String?
  siret                 String?
  email                 String?
  telephone             String?
  adresse               String?
  codePostal            String?
  ville                 String?
  notes                 String?
  statut                String                     @default("ACTIF")
  source                String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  reservationsPompe     BonReservationPompe[]
  bonsTravaux           BonTravaux[]               @relation("BTClient")
  chantiers             Chantier[]
  daacts                DAACT[]                    @relation("DAACTClient")
  demandesAppro         DemandeApprovisionnement[] @relation("DAClient")
  devis                 Devis[]
  documents             Document[]
  etatsReserves         EtatReserves[]
  factures              Facture[]
  fichesAutocontrole    FicheAutocontrole[]        @relation("FACClient")
  fichesIntervention    FicheIntervention[]        @relation("FIClient")
  fichesNonConformite   FicheNonConformite[]       @relation("FNCClient")
  pvReunions            PVReunionChantier[]        @relation("PVRCClient")
  plansAssuranceQualite PlanAssuranceQualite[]     @relation("PAQClient")
  prospects             Prospect[]
  pvsReception          PvReception[]
  rapportsHebdo         RapportHebdomadaire[]      @relation("RCHClient")
}

model Fournisseur {
  id                      String                     @id @default(cuid())
  reference               String?                    @unique
  nom                     String
  contact                 String?
  email                   String?
  telephone               String?
  adresse                 String?
  codePostal              String?
  ville                   String?
  siret                   String?
  notes                   String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  corpsMetier             String?
  articlesStock           ArticleStock[]
  bonsCommande            BonCommande[]
  bonsCommandeBeton       BonCommandeBeton[]
  bonsCommandeFournitures BonCommandeFournitures[]
  bonsLivraison           BonLivraison[]
  reservationsPompe       BonReservationPompe[]
  demandesAppro           DemandeApprovisionnement[] @relation("DAFournisseur")
  depenses                Depense[]
  documents               Document[]
  fichesNonConformite     FicheNonConformite[]       @relation("FNCFournisseur")
  pvsReception            PvReception[]
  facturesFournisseur     FactureFournisseur[]
}

model SousTraitant {
  id                  String                 @id @default(cuid())
  reference           String?                @unique
  nom                 String
  specialite          String?
  contact             String?
  email               String?
  telephone           String?
  adresse             String?
  tauxHoraire         Float?
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  couleur             String?
  capitalSocial       String?
  qualiteRepresentant String?
  rcs                 String?
  representant        String?
  siret               String?
  interventions       ChantierSousTraitant[]
  contrats            ContratSousTraitance[]
  ordresMission       OrdreMission[]
  pvsReception        PvReception[]
}

model Chantier {
  id                      String                       @id @default(cuid())
  reference               String                       @unique
  nom                     String
  clientId                String
  adresse                 String?
  codePostal              String?
  ville                   String?
  statut                  String                       @default("PROSPECT")
  dateDebut               DateTime?
  dateFin                 DateTime?
  budgetEstime            Float?
  description             String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  tokenVariantes          String?                      @unique
  approvisionements       ApprovisionementChantier[]   @relation("ACChantier")
  bonsCommande            BonCommande[]
  bonsCommandeBeton       BonCommandeBeton[]
  bonsCommandeFournitures BonCommandeFournitures[]
  bonsLivraison           BonLivraison[]
  reservationsPompe       BonReservationPompe[]
  bonsTravaux             BonTravaux[]                 @relation("BTChantier")
  client                  Client                       @relation(fields: [clientId], references: [id])
  sousTraitants           ChantierSousTraitant[]
  checklistDocuments      ChecklistDocumentChantier[]
  contrats                ContratSousTraitance[]
  coutsMateriauxRendus    CoutMateriauxRenduChantier[] @relation("CMRChantier")
  daacts                  DAACT[]                      @relation("DAACTChantier")
  doe                     DOE[]
  demandesAppro           DemandeApprovisionnement[]   @relation("DAChantier")
  depenses                Depense[]
  devis                   Devis[]
  documents               Document[]
  etatsReserves           EtatReserves[]
  etudesDebourse          EtudeDebourse[]              @relation("EDSChantier")
  evenements              Evenement[]
  factures                Facture[]
  fichesAgrement          FicheAgrementProduit[]       @relation("FAPChantier")
  fichesAutocontrole      FicheAutocontrole[]          @relation("FACChantier")
  fichesIntervention      FicheIntervention[]          @relation("FIChantier")
  fichesNonConformite     FicheNonConformite[]         @relation("FNCChantier")
  fraisChantiers          FraisChantier[]              @relation("FCChantier")
  livretAccueil           LivretAccueilConfig?
  memoiresTechniques      MemoireTechnique[]
  metres                  Metre[]
  mouvementsStock         MouvementStock[]
  notesDeFrais            NoteDeFrais[]
  ordresMission           OrdreMission[]
  ppsps                   PPSPS[]
  pvReunions              PVReunionChantier[]          @relation("PVRCChantier")
  plansAssuranceQualite   PlanAssuranceQualite[]       @relation("PAQChantier")
  preDimensionnements     PreDimensionnement[]         @relation("PDIMChantier")
  pvsReception            PvReception[]
  rapportsHebdo           RapportHebdomadaire[]        @relation("RCHChantier")
  stocksParEmplacement    StockParEmplacement[]
  heuresInterimaires      SuiviHeureInterimaire[]
  taches                  Tache[]
  tachesGantt             TacheGantt[]
  facturesFournisseur     FactureFournisseur[]
}

model LivretAccueilConfig {
  id                  String   @id @default(cuid())
  chantierId          String   @unique
  chefChantierNom     String?
  chefChantierContact String?
  natureOuvrage       String?
  descriptionChantier String?
  lotsJson            String   @default("[]")
  horairesChantier    String?
  stationnementAcces  String?
  remarqueVoisinage   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  chantier            Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
}

model ChantierSousTraitant {
  id             String       @id @default(cuid())
  chantierId     String
  sousTraitantId String
  role           String?
  chantier       Chantier     @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  sousTraitant   SousTraitant @relation(fields: [sousTraitantId], references: [id], onDelete: Cascade)

  @@unique([chantierId, sousTraitantId])
}

model ContratSousTraitance {
  id                    String       @id @default(cuid())
  numero                String       @unique
  sousTraitantId        String
  chantierId            String
  statut                String       @default("BROUILLON")
  objet                 String?
  lot                   String?
  montantHT             Float?
  tauxTVA               Float?
  modaliteReglement     String?
  retenueGarantie       Float?
  delaiExecution        String?
  dateDebut             DateTime?
  dateFin               DateTime?
  penalitesRetard       String?
  assuranceRC           String?
  notes                 String?
  signatureToken        String?      @unique
  signataireNom         String?
  signatureImage        String?
  dateSignature         DateTime?
  signatureIp           String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  clausesPersonnalisees String?
  autoLiquidationTVA    Boolean      @default(true)
  dateReception         DateTime?
  rgLiberee             Boolean      @default(false)
  chantier              Chantier     @relation(fields: [chantierId], references: [id])
  sousTraitant          SousTraitant @relation(fields: [sousTraitantId], references: [id])
}

model OrdreMission {
  id             String        @id @default(cuid())
  numero         String        @unique
  sousTraitantId String?
  chantierId     String?
  statut         String        @default("BROUILLON")
  titre          String
  description    String?
  lieu           String?
  dateDebut      DateTime
  dateFin        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  interimaireId  String?
  type           String        @default("SOUS_TRAITANT")
  chantier       Chantier?     @relation(fields: [chantierId], references: [id])
  interimaire    Interimaire?  @relation(fields: [interimaireId], references: [id])
  sousTraitant   SousTraitant? @relation(fields: [sousTraitantId], references: [id])
}

model Devis {
  id                   String                       @id @default(cuid())
  numero               String                       @unique
  chantierId           String
  clientId             String
  statut               String                       @default("BROUILLON")
  type                 String                       @default("INITIAL")
  devisParentId        String?
  dateCreation         DateTime                     @default(now())
  dateValidite         DateTime?
  version              Int                          @default(1)
  referenceMarche      String?
  maitreOuvrage        String?
  maitreOeuvre         String?
  lot                  String?
  objet                String?
  delaiExecution       String?
  modaliteReglement    String?
  modelePdf            String                       @default("APPEL_OFFRE")
  totalHT              Float                        @default(0)
  totalTVA             Float                        @default(0)
  totalTTC             Float                        @default(0)
  signatureToken       String?                      @unique
  mentionsLibres       String?
  notesInternes        String?
  modeleCouverture     String                       @default("RENOVATION")
  nomProjet            String?
  photoProjetUrl       String?
  moNom                String?
  moRepresentant       String?
  moEmail              String?
  moTelephone          String?
  moeNom               String?
  moeRepresentant      String?
  moeEmail             String?
  moeTelephone         String?
  bets                 String?
  egNom                String?
  egRepresentant       String?
  egEmail              String?
  egTelephone          String?
  spsNom               String?
  spsRepresentant      String?
  spsTelephone         String?
  opcNom               String?
  opcRepresentant      String?
  opcTelephone         String?
  bordereauDiffusion   String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  photoPositionX       Int                          @default(50)
  photoPositionY       Int                          @default(50)
  photoRotation        Int                          @default(0)
  totalDS              Float                        @default(0)
  approvisionements    ApprovisionementChantier[]   @relation("ACDevis")
  coutsMateriauxRendus CoutMateriauxRenduChantier[] @relation("CMRDevis")
  doe                  DOE[]
  chantier             Chantier                     @relation(fields: [chantierId], references: [id])
  client               Client                       @relation(fields: [clientId], references: [id])
  devisParent          Devis?                       @relation("DevisAvenants", fields: [devisParentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  avenants             Devis[]                      @relation("DevisAvenants")
  lignes               DevisLigne[]
  documents            Document[]
  etudesDebourse       EtudeDebourse[]              @relation("EDSDevis")
  factures             Facture[]
  fichesAgrement       FicheAgrementProduit[]       @relation("FAPDevis")
  fraisChantiers       FraisChantier[]              @relation("FCDevis")
  memoiresTechniques   MemoireTechnique[]
  ppsps                PPSPS[]
  signature            Signature?
}

model DevisLigne {
  id              String  @id @default(cuid())
  devisId         String
  type            String  @default("LIGNE")
  ordre           Int
  codeArticle     String?
  designation     String
  unite           String?
  quantite        Float?
  prixUnitaireHT  Float?
  remise          Float?
  tauxTVA         Float?
  totalHT         Float?
  styleTexte      String  @default("{}")
  clausesReserves String?
  sousTotalManuel Float?
  sousTotalMasque Boolean @default(false)
  coutUnitaireDS  Float?
  devis           Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model Signature {
  id             String   @id @default(cuid())
  devisId        String   @unique
  nomSignataire  String
  imageSignature String
  dateSignature  DateTime @default(now())
  adresseIp      String?
  userAgent      String?
  devis          Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model Facture {
  id               String           @id @default(cuid())
  numero           String           @unique
  chantierId       String
  clientId         String
  devisId          String?
  statut           String           @default("BROUILLON")
  type             String           @default("STANDARD")
  dateEmission     DateTime         @default(now())
  dateEcheance     DateTime?
  modelePdf        String           @default("APPEL_OFFRE")
  totalHT          Float            @default(0)
  totalTVA         Float            @default(0)
  totalTTC         Float            @default(0)
  montantPaye      Float            @default(0)
  lienPaiement     String?
  bridgeLinkId     String?
  bridgeLinkStatut String?
  mentionsLibres   String?
  notesInternes    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  documents        Document[]
  chantier         Chantier         @relation(fields: [chantierId], references: [id])
  client           Client           @relation(fields: [clientId], references: [id])
  devis            Devis?           @relation(fields: [devisId], references: [id])
  lignes           FactureLigne[]
  paiements        Paiement[]
  relances         RelanceFacture[]
}

model RelanceFacture {
  id        String   @id @default(cuid())
  factureId String
  type      String
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  facture   Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

model FactureLigne {
  id             String  @id @default(cuid())
  factureId      String
  type           String  @default("LIGNE")
  ordre          Int
  codeArticle    String?
  designation    String
  unite          String?
  quantite       Float?
  prixUnitaireHT Float?
  remise         Float?
  tauxTVA        Float?
  totalHT        Float?
  facture        Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

model Paiement {
  id          String               @id @default(cuid())
  factureId   String
  montant     Float
  date        DateTime             @default(now())
  methode     String               @default("VIREMENT")
  reference   String?
  notes       String?
  ligneReleve LigneReleveBancaire?
  facture     Facture              @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

model BonCommande {
  id            String             @id @default(cuid())
  numero        String             @unique
  fournisseurId String
  chantierId    String?
  statut        String             @default("BROUILLON")
  dateCreation  DateTime           @default(now())
  notes         String?
  totalHT       Float              @default(0)
  totalTVA      Float              @default(0)
  totalTTC      Float              @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  chantier      Chantier?          @relation(fields: [chantierId], references: [id])
  fournisseur   Fournisseur        @relation(fields: [fournisseurId], references: [id])
  lignes              BonCommandeLigne[]
  bonsLivraison       BonLivraison[]
  facturesFournisseur FactureFournisseur[]
}

model BonCommandeLigne {
  id             String      @id @default(cuid())
  bonCommandeId  String
  ordre          Int
  designation    String
  unite          String?
  quantite       Float?
  prixUnitaireHT Float?
  tauxTVA        Float?
  totalHT        Float?
  bonCommande    BonCommande @relation(fields: [bonCommandeId], references: [id], onDelete: Cascade)
}

model BonLivraison {
  id            String              @id @default(cuid())
  numero        String              @unique
  fournisseurId String
  chantierId    String?
  bonCommandeId String?
  statut        String              @default("ATTENDU")
  dateLivraison DateTime?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  bonCommande   BonCommande?        @relation(fields: [bonCommandeId], references: [id])
  chantier      Chantier?           @relation(fields: [chantierId], references: [id])
  fournisseur   Fournisseur         @relation(fields: [fournisseurId], references: [id])
  lignes        BonLivraisonLigne[]
}

model BonLivraisonLigne {
  id                String       @id @default(cuid())
  bonLivraisonId    String
  ordre             Int
  designation       String
  unite             String?
  quantiteCommandee Float?
  quantiteRecue     Float?
  notes             String?
  bonLivraison      BonLivraison @relation(fields: [bonLivraisonId], references: [id], onDelete: Cascade)
}

model BonCommandeBeton {
  id               String                      @id @default(cuid())
  numero           String                      @unique
  fournisseurId    String
  chantierId       String?
  statut           String                      @default("BROUILLON")
  nomChantier      String?
  adresseChantier  String?
  refAnalytique    String?
  modeReglement    String?
  classeResistance String?
  classeExposition String?
  consistance      String?
  affaissement     Float?
  dmax             Float?
  typeCiment       String?
  rapportEauCiment Float?
  teneurCimentMin  Float?
  adjuvant         String?
  chlorures        String?
  qteTotale        Float                       @default(0)
  prixM3           Float?
  betonPompe       Boolean                     @default(false)
  essaisBeton      Boolean                     @default(false)
  ajoutEau         Boolean                     @default(false)
  modeMiseEnOeuvre String?
  dateLivraison    DateTime?
  heureDebut       String?
  heureFin         String?
  cadenceM3h       Float?
  observations     String?
  notes            String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  totalHT          Float                       @default(0)
  totalTTC         Float                       @default(0)
  chantier         Chantier?                   @relation(fields: [chantierId], references: [id])
  fournisseur      Fournisseur                 @relation(fields: [fournisseurId], references: [id])
  livraisons       BonCommandeBetonLivraison[]
}

model BonCommandeBetonLivraison {
  id                 String           @id @default(cuid())
  bonCommandeBetonId String
  ordre              Int
  dateLivraison      DateTime
  quantiteM3         Float            @default(0)
  heureDebut         String?
  heureFin           String?
  cadenceM3h         Float?
  observations       String?
  bonCommandeBeton   BonCommandeBeton @relation(fields: [bonCommandeBetonId], references: [id], onDelete: Cascade)
}

model BonCommandeFournitures {
  id               String                        @id @default(cuid())
  numero           String                        @unique
  type             String                        @default("BUREAU")
  statut           String                        @default("BROUILLON")
  fournisseurId    String
  service          String                        @default("ADMINISTRATION")
  demandeurNom     String?
  demandeurEmail   String?
  validateurNom    String?
  refBudget        String?
  refBonLivraison  String?
  adresseLivraison String?
  dateCommande     DateTime                      @default(now())
  dateSouhaitee    DateTime?
  modeReglement    String?
  totalHT          Float                         @default(0)
  totalTVA         Float                         @default(0)
  totalTTC         Float                         @default(0)
  notes            String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  chantierId       String?
  chantier         Chantier?                     @relation(fields: [chantierId], references: [id])
  fournisseur      Fournisseur                   @relation(fields: [fournisseurId], references: [id])
  lignes           BonCommandeFournituresLigne[]
}

model BonCommandeFournituresLigne {
  id                       String                 @id @default(cuid())
  bonCommandeFournituresId String
  ordre                    Int
  categorie                String                 @default("AUTRE")
  designation              String
  reference                String?
  quantite                 Float                  @default(1)
  unite                    String                 @default("u")
  prixUnitaireHT           Float                  @default(0)
  tauxTVA                  Float                  @default(20)
  totalHT                  Float                  @default(0)
  bonCommandeFournitures   BonCommandeFournitures @relation(fields: [bonCommandeFournituresId], references: [id], onDelete: Cascade)
}

model PvReception {
  id                        String               @id @default(cuid())
  numero                    String               @unique
  statut                    String               @default("BROUILLON")
  typeSupport               String               @default("PRESTATION")
  objet                     String?
  descriptionPrestations    String?
  dateReception             DateTime?
  lieuReception             String?
  periodeDebut              DateTime?
  periodeFin                DateTime?
  refContrat                String?
  refDevis                  String?
  refCommande               String?
  refBonLivraison           String?
  clientId                  String?
  chantierId                String?
  fournisseurId             String?
  repMO                     String?
  fonctionRepMO             String?
  emailRepMO                String?
  repPrestataire            String?
  fonctionPrestataire       String?
  emailPrestataire          String?
  resultat                  String?
  motifRefus                String?
  dateEffet                 DateTime?
  garantieConformite        Boolean              @default(false)
  dureeGarantie             String?
  shareToken                String?              @unique
  shareExpiry               DateTime?
  signatureMO               String?
  signaturePrestataire      String?
  dateSignatureMO           DateTime?
  dateSignaturePrestataire  DateTime?
  notes                     String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  assuranceDONo             String?
  assuranceDecennaleNo      String?
  categorie                 String               @default("SUPPORT")
  dateFinBiennale           DateTime?
  dateFinDecennale          DateTime?
  dateFinParfaitAchevement  DateTime?
  garantieBiennale          Boolean              @default(false)
  garantieDecennale         Boolean              @default(false)
  garantiePerfaitAchevement Boolean              @default(false)
  maitreOeuvreEmail         String?
  maitreOeuvreNom           String?
  sousTraitantId            String?
  chantier                  Chantier?            @relation(fields: [chantierId], references: [id])
  client                    Client?              @relation(fields: [clientId], references: [id])
  fournisseur               Fournisseur?         @relation(fields: [fournisseurId], references: [id])
  sousTraitant              SousTraitant?        @relation(fields: [sousTraitantId], references: [id])
  lignes                    PvReceptionLigne[]
  reserves                  PvReceptionReserve[]
}

model PvReceptionLigne {
  id            String      @id @default(cuid())
  pvReceptionId String
  ordre         Int
  designation   String
  reference     String?
  quantite      Float?
  unite         String?
  conformite    String      @default("CONFORME")
  observations  String?
  pvReception   PvReception @relation(fields: [pvReceptionId], references: [id], onDelete: Cascade)
}

model PvReceptionReserve {
  id               String      @id @default(cuid())
  pvReceptionId    String
  ordre            Int
  description      String
  delaiLevee       DateTime?
  responsable      String?
  statut           String      @default("OUVERTE")
  dateLevee        DateTime?
  commentaireLevee String?
  pvReception      PvReception @relation(fields: [pvReceptionId], references: [id], onDelete: Cascade)
}

model BonReservationPompe {
  id                       String      @id @default(cuid())
  numero                   String      @unique
  statut                   String      @default("BROUILLON")
  fournisseurId            String
  chantierId               String?
  clientId                 String?
  nomChantier              String?
  adresseChantier          String?
  contactTelephone         String?
  refAnalytique            String?
  dateReservation          DateTime?
  heureArriveePompe        String?
  heureDebutPompage        String?
  heureFinPompage          String?
  cubagePrévu             Float?
  centraleBeton            String?
  typePompe                String?
  avecFleche               Boolean     @default(true)
  flecheMetres             Float?
  sansFleche               Boolean     @default(false)
