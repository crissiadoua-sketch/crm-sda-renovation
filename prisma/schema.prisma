  chantier         Chantier? @relation("DAACTChantier", fields: [chantierId], references: [id])
  client           Client?   @relation("DAACTClient", fields: [clientId], references: [id])
}

model PreDimensionnement {
  id                String                       @id @default(cuid())
  numero            String                       @unique
  titre             String?
  statut            String                       @default("BROUILLON")
  typeElement       String
  materiau          String
  portee            Float?
  condition         String?
  niveauCharge      String?
  usagePreset       String?
  effortNormal      Float?
  hauteurLibre      Float?
  resistance        Float?
  resultatValeurCm  Float?
  resultatLargeurCm Float?
  resultatLabel     String?
  formule           String?
  hypotheses        String?
  chantierId        String?
  responsable       String?
  notes             String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  portanceSol       String?
  surface           Float?
  usageDallage      String?
  debordMargelle    Float?
  finitionBeton     String?
  largeurMargelle   Float?
  lineaireM         Float?
  materiauMargelle  String?
  chantier          Chantier?                    @relation("PDIMChantier", fields: [chantierId], references: [id])
  documents         PreDimensionnementDocument[]
}

model PreDimensionnementDocument {
  id                   String             @id @default(cuid())
  preDimensionnementId String
  type                 String
  nom                  String
  url                  String
  taille               Int
  createdAt            DateTime           @default(now())
  analyseIA            String?
  analyseIADate        DateTime?
  preDimensionnement   PreDimensionnement @relation(fields: [preDimensionnementId], references: [id], onDelete: Cascade)
}

