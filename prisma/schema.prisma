  updatedAt     DateTime @updatedAt

  doe          DOE              @relation(fields: [doeId], references: [id], onDelete: Cascade)
  fiches       FicheTechnique[] @relation("DOESectionFiches")
}

// ---------------------------------------------------------------------------
// PPSPS — Plan Particulier de Sécurité et de Protection de la Santé
// ---------------------------------------------------------------------------

model PPSPS {
  id                   String   @id @default(cuid())
  // Modèle : APPEL_OFFRE | PERSONNALISE
  modele               String   @default("PERSONNALISE")
  // Statut : BROUILLON | VALIDE | TRANSMIS
  statut               String   @default("BROUILLON")
  titre                String
  reference            String?  // référence du marché / opération
  // Renseignements généraux
  nomOperation         String?
  adresseChantier      String?
  maitreOuvrage        String?
  maitreOeuvre         String?
  coordonateurSPS      String?
  dateDebutChantier    DateTime?
  dateFinChantier      DateTime?
  effectifPrevu        Int?     // nombre de travailleurs prévus
  // Entreprise
  nomEntreprise        String   @default("SDA Rénovation")
  sirenEntreprise      String   @default("988681672")
  assuranceDecennale   String?
  assuranceRC          String?
  // Contenu structuré (sections éditables)
  contenuLibre         String?  // JSON: { [sectionKey]: string } — édition manuelle des sections
  // Relations
  chantierId           String
  devisId              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  chantier  Chantier         @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  devis     Devis?           @relation(fields: [devisId], references: [id], onDelete: SetNull)
  risques   PPSPSRisque[]
  secours   PPSPSSecours[]
}

model PPSPSRisque {
  id            String  @id @default(cuid())
  ppspsId       String
  ordre         Int     @default(0)
  phase         String  // phase de travaux (terrassement, maçonnerie…)
  corpsEtat     String?
  description   String  // description du risque
  mesures       String  // mesures de prévention
  responsable   String? // personne responsable de la prévention
  priorite      String  @default("MOYEN") // FAIBLE | MOYEN | ELEVE | CRITIQUE
  epi           String? // EPI requis (JSON array)

  ppsps PPSPS @relation(fields: [ppspsId], references: [id], onDelete: Cascade)
}

model PPSPSSecours {
  id        String @id @default(cuid())
  ppspsId   String
  type      String // SAMU | POMPIERS | MEDECIN | HOPITAL | SSIAP | AUTRE
  nom       String?
  telephone String
  adresse   String?
  distance  String?

  ppsps PPSPS @relation(fields: [ppspsId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
